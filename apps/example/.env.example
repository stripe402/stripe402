# Stripe API keys (get from https://dashboard.stripe.com/test/apikeys)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Server secret for HMAC client identity derivation (use a random string in production)
SERVER_SECRET=change-me-in-production

# Minimum top-up amount in units (1 unit = 1/10000 dollar, defaults to 50000 = $5.00)
MIN_TOP_UP=50000

# Server port
PORT=3000

# Redis connection URL (used by default)
REDIS_URL=redis://redis:6379

# PostgreSQL connection URL (uncomment to use PostgresStore instead of RedisStore)
# DATABASE_URL=postgresql://stripe402:stripe402@postgres:5432/stripe402

# For client demos: a Stripe test PaymentMethod ID
# Create one via: stripe paymentmethods create --type=card -d card[token]=tok_visa
TEST_PAYMENT_METHOD_ID=pm_...

# API URL for client demos (points to the example server)
API_URL=http://localhost:3000
