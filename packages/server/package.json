{
  "name": "@stripe402/server",
  "version": "0.0.1",
  "description": "Server-side Stripe integration and persistence stores for the stripe402 protocol",
  "license": "Apache-2.0",
  "author": "Lance Whatley",
  "repository": {
    "type": "git",
    "url": "https://github.com/whatl3y/stripe402.git",
    "directory": "packages/server"
  },
  "homepage": "https://github.com/whatl3y/stripe402/tree/main/packages/server#readme",
  "bugs": {
    "url": "https://github.com/whatl3y/stripe402/issues"
  },
  "keywords": ["stripe", "402", "payment", "server", "redis", "postgres", "middleware"],
  "engines": {
    "node": ">=16.0.0"
  },
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@stripe402/core": "workspace:*",
    "stripe": "^17.7.0"
  },
  "peerDependencies": {
    "ioredis": ">=5.0.0",
    "pg": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "ioredis": { "optional": true },
    "pg": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^24.0.3",
    "@types/pg": "^8.15.4",
    "ioredis": "^5.8.2",
    "pg": "^8.16.3",
    "typescript": "^5.9.3"
  }
}
