{
  "name": "@stripe402/express",
  "version": "0.0.1",
  "description": "Express middleware for HTTP 402 payment gates using the stripe402 protocol",
  "license": "Apache-2.0",
  "author": "Lance Whatley",
  "repository": {
    "type": "git",
    "url": "https://github.com/whatl3y/stripe402.git",
    "directory": "packages/express"
  },
  "homepage": "https://github.com/whatl3y/stripe402/tree/main/packages/express#readme",
  "bugs": {
    "url": "https://github.com/whatl3y/stripe402/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": ["stripe", "402", "payment", "express", "middleware", "http", "api", "monetization"],
  "engines": {
    "node": ">=16.0.0"
  },
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "dependencies": {
    "@stripe402/core": "workspace:*",
    "@stripe402/server": "workspace:*"
  },
  "peerDependencies": {
    "express": ">=4.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.3",
    "express": "^5.1.0",
    "typescript": "^5.9.3"
  }
}
