{
  "name": "@stripe402/core",
  "version": "0.0.1",
  "description": "Protocol types, constants, header encoding/decoding, and HMAC identity derivation for the stripe402 protocol",
  "license": "Apache-2.0",
  "author": "Lance Whatley",
  "repository": {
    "type": "git",
    "url": "https://github.com/whatl3y/stripe402.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/whatl3y/stripe402/tree/main/packages/core#readme",
  "bugs": {
    "url": "https://github.com/whatl3y/stripe402/issues"
  },
  "keywords": ["stripe", "402", "payment", "http", "protocol", "headers", "hmac", "identity"],
  "engines": {
    "node": ">=16.0.0"
  },
  "sideEffects": false,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.3.5",
    "typescript": "^5.9.3"
  }
}
